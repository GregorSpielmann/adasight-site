<style>
  /* ─── Hero ─── */
  .legal-hero {
    position: relative;
    padding: 10rem 2rem 4rem;
    text-align: center;
  }
  .legal-hero-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }
  .label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: .8125rem;
    font-weight: 500;
    letter-spacing: .08em;
    color: var(--cyan);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .legal-hero h1 {
    font-family: 'Red Hat Display', sans-serif;
    font-weight: 900;
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    line-height: 1.1;
    color: var(--text);
  }

  /* ─── Prose Content ─── */
  .legal-content {
    padding: 2rem 2rem 6rem;
  }
  .prose {
    max-width: 800px;
    margin: 0 auto;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1rem;
    line-height: 1.75;
    color: var(--text-muted);
  }
  .prose h2 {
    font-family: 'Red Hat Display', sans-serif;
    font-weight: 800;
    font-size: 1.75rem;
    color: var(--text);
    margin-top: 3rem;
    margin-bottom: 1rem;
  }
  .prose h3 {
    font-family: 'Red Hat Display', sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--text);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose h4 {
    font-family: 'Red Hat Display', sans-serif;
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--text);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose p {
    margin-bottom: 1rem;
  }
  .prose a {
    color: var(--cyan);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose a:hover {
    color: #fff;
  }
  .prose ul {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .prose ul li {
    margin-bottom: 0.5rem;
  }
  .prose strong {
    color: var(--text);
    font-weight: 600;
  }

  @media (max-width: 960px) {
    .legal-hero { padding: 8rem 1.5rem 3rem; }
    .legal-content { padding: 2rem 1.5rem 4rem; }
  }
  @media (max-width: 580px) {
    .legal-hero { padding: 7rem 1rem 2rem; }
    .legal-content { padding: 1.5rem 1rem 3rem; }
    .prose { font-size: 0.9375rem; }
  }
</style>
