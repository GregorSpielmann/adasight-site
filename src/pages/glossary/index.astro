---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const terms = (await getCollection('glossary', ({ data }) => !data.draft))
  .sort((a, b) => a.data.term.localeCompare(b.data.term));

// Group by first letter
const grouped: Record<string, typeof terms> = {};
for (const t of terms) {
  const letter = t.data.term.charAt(0).toUpperCase();
  if (!grouped[letter]) grouped[letter] = [];
  grouped[letter].push(t);
}
const letters = Object.keys(grouped).sort();
---

<Base
  title="Analytics Glossary — Adasight"
  description="Learn the terminology about analytics, product, and technical terms and get their definitions here."
>

  <!-- Hero -->
  <section class="gl-hero">
    <div class="grid-bg"></div>
    <div class="gl-hero-inner">
      <p class="label">// GLOSSARY</p>
      <h1>Analytics &amp; Product Glossary</h1>
      <p class="gl-hero-sub">Learn the terminology about analytics, product, and technical terms and get their definitions here.</p>
    </div>
  </section>

  <!-- Letter Nav -->
  <nav class="gl-letter-nav">
    <div class="gl-letter-nav-inner">
      {letters.map(l => (
        <a href={`#letter-${l}`} class="gl-letter-link">{l}</a>
      ))}
    </div>
  </nav>

  <!-- Terms List -->
  <section class="gl-list">
    <div class="gl-list-inner">
      {letters.map(letter => (
        <div class="gl-group" id={`letter-${letter}`}>
          <h2 class="gl-group-letter">{letter}</h2>
          <div class="gl-group-terms">
            {grouped[letter].map(t => (
              <a href={`/glossary/${t.id}/`} class="gl-term-card">
                <h3 class="gl-term-name">{t.data.term}</h3>
                <p class="gl-term-def">{t.data.definition}</p>
                <span class="gl-term-cat">{t.data.category}</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="gl-cta">
    <p class="label">// NEED MORE THAN DEFINITIONS?</p>
    <h2 class="section-h2">We can help you implement it</h2>
    <p class="section-sub" style="margin: 0 auto 2rem;">Book a free analytics audit and let us turn terminology into action.</p>
    <a href="/contact-us" class="btn-primary">Book a Free Call</a>
  </section>

</Base>

<style>
  /* ─── Hero ─── */
  .gl-hero {
    position: relative;
    padding: 10rem 1.5rem 5rem;
    text-align: center;
    overflow: hidden;
  }
  .gl-hero-inner {
    position: relative;
    max-width: var(--max-w);
    margin: 0 auto;
  }
  .gl-hero h1 {
    font-size: clamp(32px, 4.5vw, 56px);
    max-width: 700px;
    margin: 0 auto 1.25rem;
  }
  .gl-hero-sub {
    font-size: 17px;
    color: var(--text-muted);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.8;
  }

  /* ─── Letter Nav ─── */
  .gl-letter-nav {
    padding: 0 1.5rem 2rem;
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--bg);
    border-bottom: 1px solid var(--border2);
  }
  .gl-letter-nav-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    justify-content: center;
    padding: 1rem 0;
  }
  .gl-letter-link {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-dim);
    text-decoration: none;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    transition: color 0.2s, background 0.2s;
  }
  .gl-letter-link:hover {
    color: var(--cyan);
    background: var(--cyan-dim);
  }

  /* ─── Term List ─── */
  .gl-list {
    padding: 3rem 1.5rem 4rem;
  }
  .gl-list-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }
  .gl-group {
    margin-bottom: 3rem;
  }
  .gl-group-letter {
    font-family: 'Red Hat Display', sans-serif;
    font-size: 36px;
    font-weight: 900;
    color: var(--blue);
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }
  .gl-group-terms {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1rem;
  }
  .gl-term-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.25s, transform 0.25s;
    display: flex;
    flex-direction: column;
  }
  .gl-term-card:hover {
    border-color: rgba(66, 100, 209, 0.45);
    transform: translateY(-2px);
  }
  .gl-term-name {
    font-family: 'Red Hat Display', sans-serif;
    font-size: 18px;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }
  .gl-term-def {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.6;
    flex: 1;
    margin-bottom: 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .gl-term-cat {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--cyan);
  }

  /* ─── CTA ─── */
  .gl-cta {
    text-align: center;
    padding: 4rem 1.5rem 6rem;
  }

  /* ─── Responsive ─── */
  @media (max-width: 960px) {
    .gl-group-terms {
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    }
  }
  @media (max-width: 580px) {
    .gl-hero {
      padding: 8rem 1.25rem 3rem;
    }
    .gl-group-terms {
      grid-template-columns: 1fr;
    }
    .gl-letter-link {
      width: 30px;
      height: 30px;
      font-size: 11px;
    }
  }
</style>
