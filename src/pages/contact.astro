---
import Base from '../layouts/Base.astro';
---
<Base title="Let's Talk — adasight" description="Book a free 30-minute call with the adasight team. We'll help you figure out if we're the right fit for your analytics and experimentation challenges.">
  <section style="padding: 9rem 1.5rem 6rem; max-width: 640px; margin: 0 auto; text-align: center;">
    <div class="section-label">Get in Touch</div>
    <h1 style="margin-bottom: 1rem;">Let's Talk</h1>
    <p style="margin-bottom: 2.5rem;">Book a free 30-minute call. We'll help you figure out how adasight can help your team make better data-driven decisions.</p>
    <a href="mailto:hello@adasight.com" class="btn btn-primary" style="font-size: 1.05rem; padding: 0.9rem 2rem;">
      hello@adasight.com →
    </a>
    <p style="margin-top: 1.5rem; font-size: 0.875rem;">Or find us at <a href="https://adasight.com" style="color: var(--brand);">adasight.com</a></p>
  </section>
</Base>
