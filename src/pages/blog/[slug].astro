---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<Base
  title={post.data.seo_title || post.data.title + ' — Adasight'}
  description={post.data.description}
>
  <!-- Post Header -->
  <div class="post-header">
    <div style="font-size: 3rem; margin-bottom: 20px;">{post.data.hero_emoji}</div>
    <span class="post-category">{post.data.category}</span>
    <h1>{post.data.title}</h1>
    <p class="post-meta">
      By {post.data.author} · {post.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
    </p>
  </div>

  <!-- Back link -->
  <div style="text-align:center; padding: 24px 40px 0;">
    <a href="/blog/" style="font-family:'IBM Plex Mono',monospace; font-size:12px; color:var(--text-dim); text-decoration:none; letter-spacing:0.5px; transition:color 0.2s;"
       onmouseover="this.style.color='var(--cyan)'" onmouseout="this.style.color='var(--text-dim)'">
      ← Back to Blog
    </a>
  </div>

  <!-- Content -->
  <div class="post-content">
    <Content />
  </div>

  <!-- CTA -->
  <div class="post-cta">
    <h2>Want help with analytics or experimentation?</h2>
    <p>Book a free discovery call with the Adasight team to see how we can help your company grow.</p>
    <a href="mailto:dayana.marin@adasight.com" class="btn-primary">Book a discovery call →</a>
  </div>

</Base>
