---
import Base from '../layouts/Base.astro';
---
<Base title="Adasight — Your Growth OS" description="Adasight closes the gap between data and decisions — delivering analytics infrastructure and experimentation programs as a productized, AI-powered service.">

<!-- HERO -->
<section class="hero" id="home">
  <div class="grid-bg"></div>
  <div class="hero-badge">
    <span class="hero-badge-dot"></span>
    AI-native analytics &amp; experimentation
  </div>
  <h1>
    Your <span class="cyan">Growth OS</span><br/>
    built on data,<br/>
    <span class="blue">powered by evidence</span>
  </h1>
  <p>
    We close the gap between data and decisions — delivering analytics infrastructure and experimentation programs as a productized, AI-powered service.
  </p>
  <div class="hero-btns">
    <a href="#services" class="btn-primary">Explore our services</a>
    <a href="#contact" class="btn-ghost">Book a discovery call</a>
  </div>
  <div class="hero-stats">
    <div>
      <div class="stat-num">3<span>+</span></div>
      <div class="stat-label">// TOOL PARTNERSHIPS</div>
    </div>
    <div>
      <div class="stat-num">8<span>wk</span></div>
      <div class="stat-label">// FASTEST TO LIVE EXPERIMENTS</div>
    </div>
    <div>
      <div class="stat-num">4<span>+</span></div>
      <div class="stat-label">// EXPERIMENTS / MONTH (ADVANCED)</div>
    </div>
    <div>
      <div class="stat-num">20<span>+</span></div>
      <div class="stat-label">// HYPOTHESES IN ROADMAP</div>
    </div>
  </div>
</section>

<!-- PARTNER STRIP -->
<div class="partners-strip">
  <div class="partners-inner">
    <span class="partners-label">Certified partners</span>
    <div class="partners-divider"></div>
    <div class="partners-list">
      <span class="partner">Amplitude</span>
      <span class="partner">Statsig</span>
      <span class="partner">GA4</span>
      <span class="partner">Mixpanel</span>
      <span class="partner">PostHog</span>
      <span class="partner">Heap</span>
    </div>
  </div>
</div>

<!-- ABOUT / MISSION + VISION -->
<div class="about-wrap" id="about">
  <div class="about-inner">
    <div>
      <p class="label">// WHO WE ARE</p>
      <h2 class="section-h2">The system<br/>behind your growth.</h2>
      <p class="section-sub" style="margin-bottom:28px;">
        Adasight is an AI-native analytics and experimentation agency. We believe data-driven growth shouldn't be reserved for companies with large data teams. We've productized the work of a world-class analytics function — and made it accessible to every growth-stage company.
      </p>
      <p class="section-sub">
        Our delivery is built on a reusable component system: every audit, tracking plan, experiment setup, and insight report follows a documented, repeatable process. AI accelerates the heavy lifting — so you get senior-level outcomes without the headcount.
      </p>
    </div>
    <div class="mv-cards">
      <div class="mv-card mission">
        <div class="mv-tag">// MISSION</div>
        <h3>Close the gap between data and decisions.</h3>
        <p>Help growth-stage companies build the analytics foundation and experimentation culture they need to grow with confidence — regardless of team size or budget.</p>
      </div>
      <div class="mv-card vision">
        <div class="mv-tag">// VISION</div>
        <h3>Become the operating system for growth analytics.</h3>
        <p>The layer that connects data, experimentation, and decisions for the next generation of digital companies — making the traditional consultant obsolete.</p>
      </div>
    </div>
  </div>
</div>

<!-- SLOGAN -->
<div class="slogan-wrap">
  <h2>"From data to decisions."</h2>
  <p>We replace gut-feel product choices with evidence — systematically, repeatably, at scale.</p>
</div>

<!-- HOW IT WORKS -->
<section class="section" id="how">
  <p class="label">// HOW IT WORKS</p>
  <h2 class="section-h2">A system, not a project.</h2>
  <p class="section-sub">Every engagement follows the same proven framework — from messy data to confident, evidence-backed decisions.</p>
  <div class="steps">
    <div class="step">
      <div class="step-n">01 // AUDIT</div>
      <h4>Discovery &amp; Audit</h4>
      <p>We map your data landscape, assess your stack, and identify what's broken, missing, or unreliable.</p>
    </div>
    <div class="step">
      <div class="step-n">02 // BUILD</div>
      <h4>Foundation</h4>
      <p>We implement clean tracking, define your core KPIs, and set up analytics infrastructure your team can trust.</p>
    </div>
    <div class="step">
      <div class="step-n">03 // TEST</div>
      <h4>Experimentation</h4>
      <p>We build your hypothesis pipeline, design experiments, and run structured A/B tests with clear decision frameworks.</p>
    </div>
    <div class="step">
      <div class="step-n">04 // SCALE</div>
      <h4>Ongoing Insight</h4>
      <p>We stay embedded as your analytics partner — monitoring, iterating, and turning data into recurring business decisions.</p>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section class="section" id="services" style="padding-top:0;">
  <p class="label">// SERVICES</p>
  <h2 class="section-h2">Two domains.<br/>One Growth OS.</h2>
  <p class="section-sub">Whether you need to fix your data foundation or run a full experimentation programme — we have a structured, productized path.</p>
  <div class="services-grid">

    <div class="service-card">
      <span class="svc-tag tag-data">Data &amp; Analytics</span>
      <h3>Analytics Infrastructure &amp; Insight</h3>
      <p>For companies that need to fix, build, or scale their data foundation. We go from broken tracking to clean, actionable insight — fast.</p>
      <ul class="pkg-list">
        <li><span class="arrow">→</span><span><strong>Tier 1 — Data Discovery &amp; Audit</strong> — 1-week landscape assessment</span></li>
        <li><span class="arrow">→</span><span><strong>Data Foundation Sprint</strong> — Clean tracking and core KPIs in 4 weeks</span></li>
        <li><span class="arrow">→</span><span><strong>Amplitude Implementation</strong> — Starter and full implementation packages</span></li>
        <li><span class="arrow">→</span><span><strong>Marketing Analytics Setup</strong> — Connect campaigns to retention and revenue</span></li>
        <li><span class="arrow">→</span><span><strong>Amplitude AI Readiness</strong> — Prepare your stack for AI-driven decisions</span></li>
        <li><span class="arrow">→</span><span><strong>Analytics Retainer</strong> — Light · Standard · Enterprise ongoing partnership</span></li>
      </ul>
    </div>

    <div class="service-card">
      <span class="svc-tag tag-exp">Experimentation</span>
      <h3>Experimentation Programmes</h3>
      <p>For teams ready to stop guessing and start testing. We build and run your end-to-end experimentation function — hypothesis to decision.</p>
      <ul class="pkg-list">
        <li><span class="arrow">→</span><span><strong>Starter (8 weeks)</strong> — Your first structured experimentation programme</span></li>
        <li><span class="arrow">→</span><span><strong>Standard (Monthly)</strong> — 2–3 experiments/month with weekly reviews</span></li>
        <li><span class="arrow">→</span><span><strong>Advanced (6 months)</strong> — 20-hypothesis roadmap, 3–4 experiments/month</span></li>
        <li><span class="arrow">→</span><span><strong>Statsig Integration</strong> — Full implementation and CDP connector setup</span></li>
        <li><span class="arrow">→</span><span><strong>Enablement &amp; Training</strong> — Embed experimentation culture in your team</span></li>
      </ul>
    </div>

  </div>
</section>

<!-- TIERS -->
<section class="section" id="packages" style="padding-top:0;">
  <p class="label">// EXPERIMENTATION TIERS</p>
  <h2 class="section-h2">Start where you are.<br/>Scale from there.</h2>
  <div class="tiers">
    <div class="tier">
      <div class="tier-name">Starter</div>
      <div class="tier-dur">// 8 WEEKS · FIXED SCOPE</div>
      <div class="tier-desc">For teams running their first experiments. Fast, structured, and focused.</div>
      <ul class="tier-feats">
        <li>Qualitative &amp; quantitative audit</li>
        <li>10-hypothesis prioritised roadmap</li>
        <li>1–2 experiments designed &amp; run</li>
        <li>Experiment evaluation framework</li>
        <li>Enablement session included</li>
      </ul>
    </div>
    <div class="tier featured">
      <div class="tier-best">Most popular</div>
      <div class="tier-name">Standard</div>
      <div class="tier-dur">// MONTHLY · ONGOING</div>
      <div class="tier-desc">For teams building a repeatable testing rhythm with ongoing expert support.</div>
      <ul class="tier-feats">
        <li>2–3 experiments per month</li>
        <li>High-fidelity variant design (Figma)</li>
        <li>Weekly alignment &amp; review meetings</li>
        <li>Ongoing hypothesis pipeline</li>
        <li>Experiment evaluation &amp; decisions</li>
        <li>Tracking QA on every test</li>
      </ul>
    </div>
    <div class="tier">
      <div class="tier-name">Advanced</div>
      <div class="tier-dur">// 6 MONTHS · FIXED SCOPE</div>
      <div class="tier-desc">For companies serious about building a scalable experimentation function.</div>
      <ul class="tier-feats">
        <li>Full qualitative + quantitative audit</li>
        <li>20-hypothesis prioritised roadmap</li>
        <li>3–4 experiments per month</li>
        <li>Tracking plan recommendations</li>
        <li>Team enablement &amp; training</li>
        <li>Weekly results &amp; impact reviews</li>
      </ul>
    </div>
  </div>
</section>

<!-- WHO WE SERVE -->
<div class="icp-section" id="who">
  <div class="icp-inner">
    <p class="label">// WHO WE WORK WITH</p>
    <h2 class="section-h2">Built for growth-stage teams.</h2>
    <p class="section-sub">We work best with companies that have product-market fit and are ready to scale decisions with data. Minimum 10,000 sessions/day for experimentation.</p>
    <div class="icp-grid">
      <div class="icp-card">
        <div class="icp-emoji">🛍️</div>
        <h4>E-commerce &amp; D2C</h4>
        <p>Optimising conversion funnels, cart recovery, and post-purchase flows with structured A/B testing and clean attribution.</p>
      </div>
      <div class="icp-card">
        <div class="icp-emoji">📦</div>
        <h4>B2B SaaS</h4>
        <p>Improving activation, feature adoption, and retention through product analytics and experiment-driven iteration.</p>
      </div>
      <div class="icp-card">
        <div class="icp-emoji">📱</div>
        <h4>B2C Apps</h4>
        <p>Building experimentation infrastructure for teams with high traffic and complex user behaviour to act on.</p>
      </div>
      <div class="icp-card">
        <div class="icp-emoji">🚀</div>
        <h4>Growth-Stage Startups</h4>
        <p>Getting from zero to a reliable data foundation fast — without the cost of an in-house data team.</p>
      </div>
      <div class="icp-card">
        <div class="icp-emoji">📊</div>
        <h4>Teams without a data function</h4>
        <p>Acting as an embedded analytics partner for companies that need senior data expertise without a full-time hire.</p>
      </div>
      <div class="icp-card">
        <div class="icp-emoji">🔬</div>
        <h4>CRO &amp; Optimisation Teams</h4>
        <p>Bringing rigour, tooling, and experimentation discipline to teams that already test but want better structure and results.</p>
      </div>
    </div>
  </div>
</div>

<!-- CTA -->
<section class="cta-wrap" id="contact">
  <div class="grid-bg"></div>
  <h2>Ready to turn your data<br/>into <span>decisions</span>?</h2>
  <p>Book a free discovery call. We'll assess where you are, what's blocking you, and the fastest path to impact.</p>
  <div class="cta-btns">
    <a href="mailto:dayana.marin@adasight.com" class="btn-primary">Book a discovery call →</a>
    <a href="/blog/" class="btn-ghost">Read our blog</a>
  </div>
</section>

</Base>
