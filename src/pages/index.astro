---
import Base from '../layouts/Base.astro';
---
<Base title="adasight — Turn Data Into Revenue-Driving Decisions">

  <!-- Hero -->
  <section class="hero">
    <div class="hero-eyebrow">Growth Analytics & Experimentation</div>
    <h1>Turn data into <span class="accent">revenue-driving</span> decisions</h1>
    <p class="hero-sub">We help product and growth teams measure what matters, run rigorous experiments, and build the analytics foundation to scale.</p>
    <div class="hero-actions">
      <a href="/contact/" class="btn btn-primary">Let's Talk →</a>
      <a href="/blog/" class="btn btn-outline">Read the Blog</a>
    </div>
  </section>

  <!-- Logo bar -->
  <section class="logos">
    <div class="logos-label">Trusted by 100+ high-growth companies</div>
    <div class="logos-grid">
      <span class="logo-item">Personio</span>
      <span class="logo-item">Tonic</span>
      <span class="logo-item">Candis</span>
      <span class="logo-item">Rutter</span>
      <span class="logo-item">Morrow</span>
      <span class="logo-item">Templa</span>
      <span class="logo-item">Pave</span>
      <span class="logo-item">Billie</span>
      <span class="logo-item">Lano</span>
      <span class="logo-item">Casavo</span>
    </div>
  </section>

  <!-- Services -->
  <section class="section">
    <div class="container">
      <div class="section-label">What We Do</div>
      <h2 class="section-title">Three ways we accelerate growth</h2>
      <p class="section-sub">From data infrastructure to live experiments — we cover the full analytics stack.</p>
      <div class="services-grid">
        <div class="service-card">
          <div class="service-icon">📊</div>
          <h3>Data Integrations & Analytics</h3>
          <p>Build the data foundation your team needs — clean event tracking, reliable pipelines, and dashboards that answer real questions.</p>
        </div>
        <div class="service-card">
          <div class="service-icon">🧪</div>
          <h3>Experimentation</h3>
          <p>Design, run, and analyse A/B tests with statistical rigour. Stop guessing — start knowing what drives conversion.</p>
        </div>
        <div class="service-card">
          <div class="service-icon">🤖</div>
          <h3>AI Agents for Analytics</h3>
          <p>Custom AI workflows that surface insights automatically — so your team spends time on decisions, not data wrangling.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Method -->
  <section class="section" style="background: var(--bg-card); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
    <div class="container">
      <div class="section-label">Our Method</div>
      <h2 class="section-title">The GAE system</h2>
      <p class="section-sub">A proven three-step framework used at 100+ companies to go from data chaos to compounding growth.</p>
      <div class="method-grid">
        <div class="method-step">
          <div class="step-num">1</div>
          <h3>Measure</h3>
          <p>Define the right metrics, instrument your product correctly, and build a single source of truth.</p>
        </div>
        <div class="method-step">
          <div class="step-num">2</div>
          <h3>Analyse</h3>
          <p>Understand user behaviour, identify drop-off points, and prioritise the highest-impact opportunities.</p>
        </div>
        <div class="method-step">
          <div class="step-num">3</div>
          <h3>Experiment</h3>
          <p>Run rigorous A/B tests, learn fast, and build a culture of evidence-based product decisions.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Who we help -->
  <section class="section">
    <div class="container">
      <div class="section-label">Who We Help</div>
      <h2 class="section-title">Built for ambitious teams</h2>
      <div class="personas-grid">
        <div class="persona-card">
          <h3>Product Teams</h3>
          <p>Instrument your product, understand retention, and ship data-driven features with confidence.</p>
        </div>
        <div class="persona-card">
          <h3>Growth Teams</h3>
          <p>Build your experimentation engine, optimise funnels, and compound learnings quarter over quarter.</p>
        </div>
        <div class="persona-card">
          <h3>Founders</h3>
          <p>Get analytics clarity from day one — know your north star, track it, and build a culture around it.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="cta-banner">
        <h2>Ready to turn data into decisions?</h2>
        <p>Book a free 30-minute call to see how adasight can help your team grow faster.</p>
        <a href="/contact/" class="btn btn-primary">Book a Free Call →</a>
      </div>
    </div>
  </section>

</Base>
