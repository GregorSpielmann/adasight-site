---
import Base from '../layouts/Base.astro';
import HomePageBottom from '../components/HomePageBottom.astro';

const logos = [
  'notarize', 'prewave', 'complete-sleep', 'tradezella', 'sift', 'bywit',
  'tonic', 'templa', 'candis', 'personio', 'responsescribe', 'gravystack',
  'morrow', 'navlin', 'betdex', 'healthplans', 'rutter', 'africhange',
  'cleardigital', 'ebrands', 'glamoreworld', 'handsoffceo', 'inspiringvacation',
  'jupusai', 'mightyscout', 'novo', 'output', 'redirecthealth', 'synccar',
  'tickettailor', 'tillerhq', 'torahlive', 'ultraspeaking', 'wickey', 'zellify', 'zero',
];

const calLink = 'https://cal.com/gregor.spielmann/30min?overlayCalendar=true';
---

<Base
  title="Adasight — Growth Operating System"
  description="Adasight helps startups and scale-ups from data to decisions by building analytics and experimentation systems into growth they can trust."
>

<!-- ═══════════════════ SECTION 1 — HERO ═══════════════════ -->
<section class="hero" id="hero-section">
  <div class="grid-bg"></div>

  <h3 class="hero-label">growth operating system &mdash; measure, analyze and experiment</h3>

  <h1 class="hero-h1">Turn data into revenue driving decisions</h1>

  <p class="hero-p">
    Adasight helps startups and scale-ups from data to decisions by building analytics and experimentation systems into growth they can trust.
  </p>

  <ul class="hero-bullets">
    <li><span class="bullet-dot"></span>Data Integrations &amp; Analytics</li>
    <li><span class="bullet-dot"></span>Experimentation</li>
    <li><span class="bullet-dot"></span>AI Agents for Analytics</li>
  </ul>

  <a href={calLink} class="btn-primary hero-cta">Talk to Our Team</a>

  <p class="hero-proof">Trusted by industry leaders 100+ Companies</p>
</section>

<!-- ═══════════════════ SECTION 2 — LOGO CAROUSEL ═══════════════════ -->
<section class="logos-section">
  <div class="logo-track">
    <div class="logo-strip logo-strip--left">
      {logos.map((name) => (
        <img src={`/src/assets/clients/${name}.png`} alt={name} loading="lazy" />
      ))}
      {logos.map((name) => (
        <img src={`/src/assets/clients/${name}.png`} alt={name} loading="lazy" />
      ))}
    </div>
  </div>
  <div class="logo-track">
    <div class="logo-strip logo-strip--right">
      {[...logos].reverse().map((name) => (
        <img src={`/src/assets/clients/${name}.png`} alt={name} loading="lazy" />
      ))}
      {[...logos].reverse().map((name) => (
        <img src={`/src/assets/clients/${name}.png`} alt={name} loading="lazy" />
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════ SECTION 3 — WHY CHOOSE US ═══════════════════ -->
<section class="why-section">
  <div class="why-inner">
    <p class="label">// WHY CHOOSE US</p>
    <h2 class="section-h2">Three reasons to work with us</h2>

    <div class="why-grid">
      <div class="why-card">
        <img src="/src/assets/icons/costs.svg" alt="" class="why-icon" />
        <h3>Drive Revenue &amp; Save Costs</h3>
        <p>No more bottle necks with data integrations, analytics, experiments.</p>
        <p class="why-sub">Run smarter A/B tests and experiments that drive measurable impact.</p>
      </div>

      <div class="why-card">
        <img src="/src/assets/icons/growth.svg" alt="" class="why-icon" />
        <h3>100+ Companies Supported</h3>
        <p>We've helped 100+ product and marketing teams</p>
        <p class="why-sub">Our clients Include Personio, Proof, Rutter API, Candis, Prewave, Sift, Ultraspeaking, and many more.</p>
      </div>

      <div class="why-card">
        <img src="/src/assets/icons/time.svg" alt="" class="why-icon" />
        <h3>Top 1% Talent</h3>
        <p>Our team are practitioners from tech companies like Booking.com, Amplitude, Make.com, Crunchyroll, Gojek and more.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════ SECTION 4 — METHOD (GAE) ═══════════════════ -->
<section class="method-wrap">
  <div class="method-section">
  <div class="method-inner">
    <p class="label">// OUR 3 STEP METHOD</p>
    <h2 class="section-h2">Growth Analytics Engine (GAE) &mdash; Powered by AI</h2>
    <p class="section-sub">
      Growth Analytics Engine (GAE) is a system that turns data into confident decisions. It unifies analytics, insights, and experimentation into a feedback loop where our systems help companies scale growth by improving how decisions are made. Revenue impact and ROI come from turning analytics into decisions.
    </p>
    <div class="method-image">
      <img src="/src/assets/icons/3-step-method.svg" alt="3 Step Method — Growth Analytics Engine" />
    </div>
    <a href="/about-us" class="btn-ghost">Learn More</a>
  </div>
  </div>
</section>

<!-- ═══════════════════ SECTION 5 — WHO WE HELP ═══════════════════ -->
<section class="who-section">
  <div class="who-inner">
    <p class="label">// WHO WE HELP</p>
    <h2 class="section-h2">Built for teams that want to turn insights into action</h2>
    <p class="section-sub">
      From product, marketing leaders, tech teams to startup founders — Adasight supports those who are serious about clarity, speed, and scaling what works.
    </p>

    <div class="who-grid">
      <div class="who-card">
        <img src="/src/assets/icons/product-teams.svg" alt="" class="who-icon" />
        <h3>Product Teams</h3>
        <p>We help product teams understand user behavior and prioritize what to build next with reliable tracking, clear insights, and experimentation.</p>
      </div>

      <div class="who-card">
        <img src="/src/assets/icons/growth-teams.svg" alt="" class="who-icon" />
        <h3>Growth Teams</h3>
        <p>We help marketing teams get reliable attribution, clear funnel visibility, and performance insights across channels, so they know what's actually driving revenue.</p>
      </div>

      <div class="who-card">
        <img src="/src/assets/icons/founders.svg" alt="" class="who-icon" />
        <h3>Founders</h3>
        <p>We give founders clear, trustworthy visibility into what's driving growth, so they can make confident decisions. We help them focus on the few levers that actually move the business forward.</p>
      </div>
    </div>

    <div class="who-cta">
      <a href={calLink} class="btn-primary">Let's Talk</a>
    </div>
  </div>
</section>

<HomePageBottom />

</Base>

<style>
  /* ═══════════════════════════════════════════════════════════════════
     SECTION 1 — HERO
     ═══════════════════════════════════════════════════════════════════ */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 130px 40px 80px;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: 1000px;
    height: 600px;
    background: radial-gradient(ellipse, rgba(66, 100, 209, 0.2) 0%, transparent 65%);
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border), transparent);
  }

  .hero-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--cyan);
    letter-spacing: 2px;
    margin-bottom: 28px;
    line-height: 1.4;
  }

  .hero-h1 {
    font-family: 'Red Hat Display', sans-serif;
    font-size: clamp(46px, 6.5vw, 84px);
    font-weight: 900;
    letter-spacing: -2.5px;
    max-width: 960px;
    margin-bottom: 26px;
    line-height: 1.05;
    color: var(--text);
  }

  .hero-p {
    font-size: 18px;
    color: var(--text-muted);
    max-width: 580px;
    margin-bottom: 36px;
    line-height: 1.8;
  }

  .hero-bullets {
    display: flex;
    gap: 28px;
    list-style: none;
    margin-bottom: 42px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-bullets li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-muted);
  }

  .bullet-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--cyan);
    flex-shrink: 0;
  }

  .hero-cta {
    margin-bottom: 56px;
  }

  .hero-proof {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  /* ═══════════════════════════════════════════════════════════════════
     SECTION 2 — LOGO CAROUSEL
     ═══════════════════════════════════════════════════════════════════ */
  .logos-section {
    background: var(--bg2);
    padding: 48px 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 28px;
    border-top: 1px solid var(--border2);
    border-bottom: 1px solid var(--border2);
  }

  .logo-track {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, black 8%, black 92%, transparent);
    mask-image: linear-gradient(90deg, transparent, black 8%, black 92%, transparent);
  }

  .logo-strip {
    display: flex;
    align-items: center;
    gap: 56px;
    width: max-content;
  }

  .logo-strip--left {
    animation: scrollLeft 60s linear infinite;
  }

  .logo-strip--right {
    animation: scrollRight 60s linear infinite;
  }

  .logo-strip img {
    height: 40px;
    width: auto;
    opacity: 0.5;
    filter: brightness(0) invert(1);
    flex-shrink: 0;
    transition: opacity 0.3s;
  }

  .logo-strip img:hover {
    opacity: 0.8;
  }

  @keyframes scrollLeft {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes scrollRight {
    0% { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }

  /* ═══════════════════════════════════════════════════════════════════
     SECTION 3 — WHY CHOOSE US
     ═══════════════════════════════════════════════════════════════════ */
  .why-section {
    padding: 100px 40px;
    max-width: 1160px;
    margin: 0 auto;
  }

  .why-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
    margin-top: 52px;
  }

  .why-card {
    background: var(--bg2);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    padding: 36px;
    transition: border-color 0.25s, transform 0.25s;
  }

  .why-card:hover {
    border-color: var(--border);
    transform: translateY(-3px);
  }

  .why-icon {
    width: 44px;
    height: 44px;
    margin-bottom: 22px;
  }

  .why-card h3 {
    font-family: 'Red Hat Display', sans-serif;
    font-size: 19px;
    font-weight: 800;
    letter-spacing: -0.4px;
    margin-bottom: 12px;
    color: var(--text);
  }

  .why-card p {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.75;
    margin-bottom: 8px;
  }

  .why-sub {
    font-size: 13px !important;
    color: var(--text-dim) !important;
    line-height: 1.7;
  }

  /* ═══════════════════════════════════════════════════════════════════
     SECTION 4 — METHOD (GAE)
     ═══════════════════════════════════════════════════════════════════ */
  .method-wrap {
    background: var(--bg2);
    border-top: 1px solid var(--border2);
    border-bottom: 1px solid var(--border2);
  }

  .method-section {
    padding: 100px 40px;
    max-width: 1160px;
    margin: 0 auto;
  }

  .method-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .method-inner .section-sub {
    max-width: 720px;
    margin-bottom: 56px;
  }

  .method-image {
    display: flex;
    justify-content: center;
    margin-bottom: 48px;
  }

  .method-image img {
    max-width: 800px;
    width: 100%;
    height: auto;
  }

  /* ═══════════════════════════════════════════════════════════════════
     SECTION 5 — WHO WE HELP
     ═══════════════════════════════════════════════════════════════════ */
  .who-section {
    padding: 100px 40px;
    max-width: 1160px;
    margin: 0 auto;
  }

  .who-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .who-inner .section-sub {
    max-width: 620px;
    margin-bottom: 0;
  }

  .who-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
    margin-top: 52px;
  }

  .who-card {
    background: var(--bg2);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    padding: 36px;
    transition: border-color 0.25s, transform 0.25s;
  }

  .who-card:hover {
    border-color: var(--border);
    transform: translateY(-3px);
  }

  .who-icon {
    width: 44px;
    height: 44px;
    margin-bottom: 22px;
  }

  .who-card h3 {
    font-family: 'Red Hat Display', sans-serif;
    font-size: 19px;
    font-weight: 800;
    letter-spacing: -0.4px;
    margin-bottom: 12px;
    color: var(--text);
  }

  .who-card p {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.75;
  }

  .who-cta {
    text-align: center;
    margin-top: 52px;
  }

  /* ═══════════════════════════════════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════════════════════════════════ */
  @media (max-width: 960px) {
    .hero {
      padding: 110px 24px 60px;
    }

    .why-section,
    .method-section,
    .who-section {
      padding: 80px 24px;
    }

    .why-grid,
    .who-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .hero-bullets {
      gap: 16px;
    }
  }

  @media (max-width: 580px) {
    .hero {
      padding: 100px 20px 48px;
      min-height: auto;
    }

    .hero-h1 {
      letter-spacing: -1.5px;
    }

    .hero-p {
      font-size: 16px;
    }

    .hero-bullets {
      flex-direction: column;
      gap: 10px;
      align-items: center;
    }

    .why-section,
    .method-section,
    .who-section {
      padding: 64px 20px;
    }

    .why-grid,
    .who-grid {
      grid-template-columns: 1fr;
    }

    .logo-strip img {
      height: 30px;
    }

    .logos-section {
      padding: 32px 0;
      gap: 20px;
    }
  }
</style>
