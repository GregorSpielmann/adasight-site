---
export interface Props {
  title: string;
  description?: string;
  image?: string;
}
const { title, description = "adasight — turn data into revenue-driving decisions. Growth analytics & experimentation consultancy.", image } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <title>{title}</title>
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />
  {image && <meta property="og:image" content={image} />}
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <!-- Favicon placeholder -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <!-- Nav -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">ada<span>sight</span></a>
      <div class="nav-links">
        <a href="/blog/">Blog</a>
        <a href="/expertise/">Expertise</a>
        <a href="/success-stories/">Case Studies</a>
        <a href="/toolkit/">Toolkit</a>
        <a href="/contact/" class="nav-cta">Let's Talk</a>
      </div>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-logo">ada<span>sight</span></div>
      <div class="footer-copy">© {new Date().getFullYear()} adasight. All rights reserved.</div>
    </div>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
