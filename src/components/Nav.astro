  .mobile-cta {
    display: inline-block;
    background: #4264D1;
    color: white;
    padding: 14px 28px;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    text-align: center;
    margin-top: 8px;
    transition: background 0.2s;
  }

  .mobile-cta:hover {
    background: #5577e8;
