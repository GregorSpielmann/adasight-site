<script>
  const hamburger = document.querySelector('.hamburger');
  const mobileMenu = document.getElementById('mobile-menu');

  hamburger?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('is-open');
    hamburger.classList.toggle('is-open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.remove('is-open');
      hamburger?.classList.remove('is-open');
      hamburger?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });
  });

  // ── Mega-menu: L-shaped hover logic ──────────────────
  const megaCats = document.querySelectorAll<HTMLButtonElement>('.mega-cat[data-cat]');
  const megaGroups = document.querySelectorAll<HTMLDivElement>('.mega-pkg-group[data-group]');

  megaCats.forEach(cat => {
    cat.addEventListener('mouseenter', () => {
      const key = cat.dataset.cat;
      megaCats.forEach(c => c.classList.remove('is-active'));
      megaGroups.forEach(g => g.classList.remove('is-active'));
      cat.classList.add('is-active');
      document.querySelector(`.mega-pkg-group[data-group="${key}"]`)?.classList.add('is-active');
    });
  });
</script>

<style>
  /* ── Nav bar ─────────────────────────────────────── */
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 60px;
    height: 68px;
    background: rgba(8, 7, 24, 0.88);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-bottom: 1px solid rgba(66, 100, 209, 0.18);
  }

  /* ── Logo ────────────────────────────────────────── */
  .nav-logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    text-decoration: none;
  }

  .nav-logo .logo-desktop {
    height: 28px;
    width: auto;
    display: block;
  }

  .nav-logo .logo-mobile {
    height: 28px;
    width: auto;
    display: none;
  }

  /* ── Center nav links ────────────────────────────── */
  .nav-center {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 32px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    color: #8890B8;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: color 0.2s;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 0;
    line-height: 68px;
  }

  .nav-link:hover {
    color: #F0F2FF;
  }

  .chevron {
    transition: transform 0.2s;
  }

  /* ── Dropdown ────────────────────────────────────── */
  .has-dropdown {
    position: relative;
  }

  .dropdown {
    position: absolute;
    top: calc(100%);
    left: 50%;
    transform: translateX(-50%);
    background: #0d0c22;
    border: 1px solid rgba(66, 100, 209, 0.18);
    border-radius: 8px;
    padding: 6px 0;
    min-width: 260px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.15s, visibility 0.15s, transform 0.15s;
    transform: translateX(-50%) translateY(4px);
    list-style: none;
    margin: 0;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
  }

  .has-dropdown:hover .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .has-dropdown:hover .chevron {
    transform: rotate(180deg);
  }

  .dropdown li a {
    display: block;
    padding: 10px 20px;
    color: #8890B8;
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
  }

  .dropdown li a:hover {
    color: #F0F2FF;
    background: rgba(66, 100, 209, 0.08);
  }

  /* ── Mega-menu ─────────────────────────────────────── */
  .has-mega {
    position: static;
  }

  .has-mega .dropdown-trigger {
    line-height: 68px;
  }

  .mega-menu {
    position: absolute;
    top: 68px;
    left: 50%;
    transform: translateX(-50%);
    width: 680px;
    display: flex;
    background: #0d0c22;
    border: 1px solid rgba(66, 100, 209, 0.18);
    border-top: none;
    border-radius: 0 0 12px 12px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.18s, visibility 0.18s;
    z-index: 1000;
  }

  .has-mega:hover .mega-menu {
    opacity: 1;
    visibility: visible;
  }

  .has-mega:hover .chevron {
    transform: rotate(180deg);
  }

  /* ── Left column: categories ─── */
  .mega-categories {
    width: 220px;
    flex-shrink: 0;
    padding: 16px 0;
    border-right: 1px solid rgba(66, 100, 209, 0.12);
    display: flex;
    flex-direction: column;
  }

  .mega-cat {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    padding: 12px 20px;
    background: none;
    border: none;
    color: #8890B8;
    font-family: inherit;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
    text-align: left;
    border-left: 2px solid transparent;
  }

  .mega-cat:hover {
    color: #F0F2FF;
    background: rgba(66, 100, 209, 0.06);
  }

  .mega-cat.is-active {
    color: #F0F2FF;
    background: rgba(66, 100, 209, 0.1);
    border-left-color: #4264D1;
  }

  .mega-cat-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    opacity: 0.5;
    transition: opacity 0.15s;
  }

  .mega-cat.is-active .mega-cat-icon,
  .mega-cat:hover .mega-cat-icon {
    opacity: 0.9;
  }

  .mega-cat-footer {
    margin-top: auto;
    padding: 12px 20px 4px;
    border-top: 1px solid rgba(66, 100, 209, 0.1);
  }

  .mega-all-link {
    font-size: 12px;
    font-weight: 500;
    color: #4264D1;
    text-decoration: none;
    transition: color 0.15s;
  }

  .mega-all-link:hover {
    color: #5577e8;
  }

  /* ── Right column: packages ─── */
  .mega-packages {
    flex: 1;
    padding: 16px 20px;
    min-height: 200px;
    position: relative;
  }

  .mega-pkg-group {
    display: none;
  }

  .mega-pkg-group.is-active {
    display: block;
  }

  .mega-pkg-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #4A5080;
    margin: 0 0 8px 0;
    padding: 0;
  }

  .mega-pkg-label:not(:first-child) {
    margin-top: 16px;
  }

  .mega-pkg-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px;
    border-radius: 6px;
    color: #8890B8;
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    transition: color 0.15s, background 0.15s;
  }

  .mega-pkg-item:hover {
    color: #F0F2FF;
    background: rgba(66, 100, 209, 0.08);
  }

  .mega-pkg-arrow {
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.15s, transform 0.15s;
    font-size: 14px;
  }

  .mega-pkg-item:hover .mega-pkg-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── CTA button ──────────────────────────────────── */
  .nav-cta {
    background: #4264D1;
    color: white;
    padding: 9px 20px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .nav-cta:hover {
    background: #5577e8;
    transform: translateY(-1px);
  }

  /* ── Hamburger ───────────────────────────────────── */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 1001;
  }

  .hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    background: #8890B8;
    border-radius: 2px;
    transition: transform 0.3s, opacity 0.3s;
  }

  .hamburger.is-open .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .hamburger.is-open .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .hamburger.is-open .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Mobile menu ─────────────────────────────────── */
  .mobile-menu {
    position: fixed;
    top: 68px;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(8, 7, 24, 0.96);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    z-index: 999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s, visibility 0.25s;
    overflow-y: auto;
  }

  .mobile-menu.is-open {
    opacity: 1;
    visibility: visible;
  }

  .mobile-menu-inner {
    padding: 32px 24px 48px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .mobile-section {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .mobile-section-label {
