<!-- ═══════════════════════════════════════════════════════════════════
     CLIENT SCRIPTS — Tech tabs + FAQ accordion
     ═══════════════════════════════════════════════════════════════════ -->
<script>
  /* ─── Tech Tab Filtering ──────────────────────────────────────── */
  document.addEventListener('astro:page-load', initHomeBottom);
  document.addEventListener('DOMContentLoaded', initHomeBottom);

  function initHomeBottom() {
    // Tech tabs
    const tabs = document.querySelectorAll('.tech-tab');
    const cards = document.querySelectorAll('.tech-card');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        const filter = tab.getAttribute('data-filter');

        cards.forEach(card => {
          if (filter === 'all' || card.getAttribute('data-category') === filter) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });

    // FAQ accordion
    const faqItems = document.querySelectorAll('.faq-item');

    faqItems.forEach(item => {
      const btn = item.querySelector('.faq-question');
      if (!btn) return;

      btn.addEventListener('click', () => {
        const isOpen = item.classList.contains('open');

        // Close all
        faqItems.forEach(fi => {
          fi.classList.remove('open');
          const b = fi.querySelector('.faq-question');
          if (b) b.setAttribute('aria-expanded', 'false');
        });

        // Open clicked (if it wasn't already open)
        if (!isOpen) {
          item.classList.add('open');
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });
  }
</script>

